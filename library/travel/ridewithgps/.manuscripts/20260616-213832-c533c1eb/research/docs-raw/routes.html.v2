</div>
</div>

<div class='api-content'>
<div class='api-content-inner'>
<link href='https://cdn.jsdelivr.net/npm/swagger-ui-dist@5/swagger-ui.css' rel='stylesheet'>
<script src='https://cdn.jsdelivr.net/npm/swagger-ui-dist@5/swagger-ui-bundle.js'></script>
<script src='https://cdn.jsdelivr.net/npm/swagger-ui-dist@5/swagger-ui-standalone-preset.js'></script>
<h1>Routes Endpoints</h1>
<div class='swagger-ui-container' id='swagger-ui'></div>
<script>
  const CustomParametersPlugin = () => ({
    wrapComponents: {
      parameters: (Original, { React }) => (props) => {
        const { parameters } = props;
        if (!parameters || parameters.size === 0) return null;
  
        const h = React.createElement;
        return h('div', { className: 'opblock-section' },
          h('div', { className: 'opblock-section-header' },
            h('h4', { className: 'opblock-title parameter__name' }, 'Parameters')
          ),
          h('div', { className: 'table-container' },
            h('table', { className: 'parameters' },
              h('thead', null,
                h('tr', null,
                  h('th', { className: 'col_header parameters-col_name' }, 'Name'),
                  h('th', { className: 'col_header parameters-col_in' }, 'Location'),
                  h('th', { className: 'col_header parameters-col_type' }, 'Type'),
                  h('th', { className: 'col_header parameters-col_description' }, 'Description')
                )
              ),
              h('tbody', null,
                parameters.map((param, i) => {
                  const name = param.get('name');
                  const description = param.get('description') || '';
                  const schema = param.get('schema');
                  const type = schema ? schema.get('type') : param.get('type') || '';
                  const required = param.get('required');
                  const location = param.get('in');
  
                  return h('tr', { key: i },
                    h('td', { className: 'parameters-col_name' },
                      h('span', { className: required ? 'parameter__name required' : 'parameter__name' }, name)
                    ),
                    h('td', { className: 'parameters-col_in' }, location),
                    h('td', { className: 'parameters-col_type' }, type),
                    h('td', { className: 'parameters-col_description' }, description)
                  );
                }).toArray()
              )
            )
          )
        );
      }
    }
  });
  
  document.addEventListener('DOMContentLoaded', function() {
    const specUrl = 'https://ridewithgps.com/api/v1/openapi/openapi_routes.yaml';
  
    window.ui = SwaggerUIBundle({
      url: specUrl,
      dom_id: '#swagger-ui',
      deepLinking: true,
      defaultModelsExpandDepth: 99,
      defaultModelExpandDepth: 99,
      presets: [
        SwaggerUIBundle.presets.apis,
        // SwaggerUIStandalonePreset
      ],
      plugins: [
        CustomParametersPlugin
      ],
      layout: "BaseLayout",
      deepLinking: false,
      supportedSubmitMethods: [],
      displayRequestDuration: true,
      docExpansion: "list",
      showExtensions: true,
      showCommonExtensions: true,
      tryItOutEnabled: true,
      filter: false,
      syntaxHighlight: {
        activate: false,
        theme: "nord"
      },
      displayOperationId: false,
      showMutatedRequest: true,
      persistAuthorization: false,
      withCredentials: false,
      onComplete: function() {
        console.log('Swagger UI loaded successfully');
      },
      onFailure: function(error) {
        console.error('Swagger UI error:', error);
        document.getElementById('swagger-ui').innerHTML = `
          <div style="padding: 2rem; text-align: center;">
            <h3>Failed to Load Documentation</h3>
            <p>Error: ${error.message || 'Unknown error'}</p>
            <p>Spec URL: ${specUrl}</p>
          </div>
        `;
      }
    });
  });
</script>

</div>
